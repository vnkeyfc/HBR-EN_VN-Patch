    {
      "Index": 0,
      "Enabled": true,
      "StartSecond": 10.763,
      "EndSecond": 107.364,
      "OriginalText": "This is My Dying Cry! This is Me Half-dying!",
      "Text": "",
      "Style": {}
    },
    {
      "Index": 1,
      "Enabled": true,
      "StartSecond": 21.064,
      "EndSecond": 25.553,
      "OriginalText": "This is My Dying Cry! This is Me Dying At Last!",
      "Text": "",
      "Style": {}
    },
    {
      "Index": 2,
      "Enabled": true,
      "StartSecond": 25.553,
      "EndSecond": 30.752,
      "OriginalText": "I've got a clear view ahead",
      "Text": "",
      "Style": {}
    },
    {
      "Index": 3,
      "Enabled": true,
      "StartSecond": 30.752,
      "EndSecond": 35.764,
      "OriginalText": "Still, my heart's made of permafrost",
      "Text": "",
      "Style": {}
    },
    {
      "Index": 4,
      "Enabled": true,
      "StartSecond": 35.764,
      "EndSecond": 40.854,
      "OriginalText": "There, they keep, keep, keep piling up to no end",
      "Text": "",
      "Style": {}
    },
    {
      "Index": 5,
      "Enabled": true,
      "StartSecond": 40.854,
      "EndSecond": 45.654,
      "OriginalText": "All these pathetic desires of mine",
      "Text": "",
      "Style": {}
    },
    {
      "Index": 6,
      "Enabled": true,
      "StartSecond": 45.654,
      "EndSecond": 50.756,
      "OriginalText": "Just try and live on your own",
      "Text": "",
      "Style": {}
    },
    {
      "Index": 7,
      "Enabled": true,
      "StartSecond": 50.756,
      "EndSecond": 56.362,
      "OriginalText": "That habit of looking down your nose",
      "Text": "",
      "Style": {}
    },
    {
      "Index": 8,
      "Enabled": true,
      "StartSecond": 56.362,
      "EndSecond": 61.459,
      "OriginalText": "It'll all break down, down, down, down before long",
      "Text": "",
      "Style": {}
    },
    {
      "Index": 9,
      "Enabled": true,
      "StartSecond": 61.459,
      "EndSecond": 66.155,
      "OriginalText": "And you'll lose all your motivation",
      "Text": "",
      "Style": {}
    },
    {
      "Index": 10,
      "Enabled": true,
      "StartSecond": 66.155,
      "EndSecond": 71.258,
      "OriginalText": "Did something good happen?",
      "Text": "",
      "Style": {}
    },
    {
      "Index": 11,
      "Enabled": true,
      "StartSecond": 71.258,
      "EndSecond": 76.966,
      "OriginalText": "Who will you celebrate it with?",
      "Text": "",
      "Style": {}
    },
    {
      "Index": 12,
      "Enabled": true,
      "StartSecond": 76.966,
      "EndSecond": 81.966,
      "OriginalText": "That thrill in your heart will fade away",
      "Text": "",
      "Style": {}
    },
    {
      "Index": 13,
      "Enabled": true,
      "StartSecond": 81.966,
      "EndSecond": 87.16,
      "OriginalText": "And when your mania comes to an end,",
      "Text": "",
      "Style": {}
    },
    {
      "Index": 14,
      "Enabled": true,
      "StartSecond": 87.16,
      "EndSecond": 89.256,
      "OriginalText": "With a straight face, Dance! Dance! Dance!",
      "Text": "",
      "Style": {}
    },
    {
      "Index": 15,
      "Enabled": true,
      "StartSecond": 89.256,
      "EndSecond": 96.958,
      "OriginalText": "Take my hand, we'll show them all!",
      "Text": "",
      "Style": {}
    }
  ]
